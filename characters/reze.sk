options:
	prefix: &7&l[&c&lGame&7&l]
	characterId: reze

on load:
	set {_value} to ""
	set {_signature} to ""
	registerSkin("{@characterId}", {_value}, {_signature})

	set {character::{@characterId}::head} to head from value {_value}
	registerCharacter("{@characterId}", 4, 20, 1, 1, 1)

	set {_lore::1} to ""
	set {_lore::2} to "&b&l&nвҠұ&7гӮӯгғЈгғ©иӘ¬жҳҺ"
	set {_lore::3} to ""
	add "&fгҖҢгғҮгғігӮёеҗӣгҒ®зҹҘгӮүгҒӘгҒ„дәӢгҖҒгҒ§гҒҚгҒӘгҒ„дәӢгҖӮз§ҒгҒҢе…ЁйғЁж•ҷгҒҲгҒҰгҒӮгҒ’гӮӢгҖӮгҖҚ" to {_lore::*}
	set {character::{@characterId}::icon} to getHeadFromCharacterId("{@characterId}") named "&7[&6&lгғҒгӮ§гғігӮҪгғјгғһгғі&7] &5&lгғ¬гӮј" with lore {_lore::*}

	delete {_lore::*}
	add "" to {_lore::*}
	add "&e&mв•Ӣв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв•Ӣ" to {_lore::*}
	add "" to {_lore::*}
	add " &b&l&nвҠұ&7жҡҙеҠӣгҒҷгӮӢ" to {_lore::*}
	add "" to {_lore::*}
	add "&e&mв•Ӣв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв•Ӣ" to {_lore::*}
	add "" to {_lore::*}
	set {_item} to raw iron of sharpness 1 with model data 1 named "&f&l&nж®ҙгӮӢ" with lore {_lore::*} with custom nbt from "{actionId:1}"
	registerAction("{@characterId}", 1, hideItemInfo({_item}))

	delete {_lore::*}
	add "" to {_lore::*}
	add "&e&mв•Ӣв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв•Ӣ" to {_lore::*}
	add "" to {_lore::*}
	add " &b&l&nвҠұ&7жҡҙеҠӣгҒҷгӮӢ" to {_lore::*}
	add "" to {_lore::*}
	add "&e&mв•Ӣв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв•Ӣ" to {_lore::*}
	add "" to {_lore::*}
	set {_item} to rabbit foot of sharpness 1 with model data 1 named "&f&l&nи№ҙгӮӢ" with lore {_lore::*} with custom nbt from "{actionId:2}"
	registerAction("{@characterId}", 2, hideItemInfo({_item}))

	delete {_lore::*}
	add "" to {_lore::*}
	add "&e&mв•Ӣв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв•Ӣ" to {_lore::*}
	add "" to {_lore::*}
	add " &b&l&nвҠұ&7ж®ӢгӮҠдҪ“еҠӣгҒҢ5вқӨд»ҘдёӢгҒ®е ҙеҗҲ&4&lгғңгғ &7гҒ«еӨүиә«гҒҷгӮӢ" to {_lore::*}
	add "" to {_lore::*}
	add "&e&mв•Ӣв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв•Ӣ" to {_lore::*}
	add "" to {_lore::*}
	set {_item} to getHeadFromCharacterId("bomb") named "&4&lгғңгғ " with lore {_lore::*} with custom nbt from "{actionId:3}"
	registerAction("{@characterId}", 3, hideItemInfo({_item}))

function {@characterId}_action1(player: player):
	cooldown({_player}, {_player}'s tool, 2 second)
	distance between {_player} and {_player}'s target player <= 4.5
	force {_player} to damage {_player}'s target player by 1 heart

function {@characterId}_action2(player: player):
	cooldown({_player}, {_player}'s tool, 3 second)
	distance between {_player} and {_player}'s target player <= 4.5
	force {_player} to damage {_player}'s target player by 2 heart

function {@characterId}_action3(player: player):
	cooldown({_player}, {_player}'s tool, 10 second)
	if health of {_player} <= 10:
		setPlayerCharacterId({_player}, "bomb")
		setSkin({_player}, "bomb")

		clear {_player}'s inventory
		giveCharacterItems({_player})
		setKBResistance({_player}, 1)
		setHealthPlayer({_player}, getHealthCharacter(getPlayerCharacterId({_player})))
		setWeightPlayer({_player}, getWeightCharacter(getPlayerCharacterId({_player})))
		setSpeedPlayer({_player}, getSpeedCharacter(getPlayerCharacterId({_player})))
		setJumpPlayer({_player}, getJumpCharacter(getPlayerCharacterId({_player})))
		heal {_player} by 10 heart

		create fake explosion at {_player}
		command "/particle minecraft:explosion %x-loc of {_player}% %y-loc of {_player}% %z-loc of {_player}% 1.5 1.5 1.5 1 100"
		play sound "custom:bomb" to all players where [distance between {_player} and input <= 20]