options:
	prefix: &7&l[&c&lSS&9&lB&7&l]

on load:
	set {character::zombie::head} to head from getSkin("zombie")
	registerCharacter("zombie", 0, 20, 1, 1, 1)

	set {_lore::1} to ""
	set {_lore::2} to "&b&l&n⊱&7全てのステータスが平均的な初心者向けキャラクター"
	set {_lore::3} to ""
	set {character::zombie::icon} to getHeadFromCharacterId("zombie") named "&7[&a&lMinecraft&7] &5&lゾンビ" with lore {_lore::*}

	delete {_lore::*}
	add "" to {_lore::*}
	add "&e&m╋━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━╋" to {_lore::*}
	add "" to {_lore::*}
	add " &b&l&n⊱&7全身の細胞を鼓舞させ、短時間の間身体能力を飛躍的に向上させる。" to {_lore::*}
	add " &b&l&n⊱&7身体に大きな負担がかかるため、再使用には長時間を要する。" to {_lore::*}
	add "" to {_lore::*}
	add "&e&m╋━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━╋" to {_lore::*}
	add "" to {_lore::*}
	set {_item} to coal of sharpness 1 with model data 1 named "&c&l&n肉体の活性化" with lore {_lore::*} with custom nbt from "{actionId:1}"
	registerAction("zombie", 1, hideItemInfo({_item}))

	delete {_lore::*}
	add "" to {_lore::*}
	add "&e&m╋━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━╋" to {_lore::*}
	add "" to {_lore::*}
	add " &b&l&n⊱&7異様な生への執着に駆られる細胞が自己修復を開始する。" to {_lore::*}
	add "" to {_lore::*}
	add "&e&m╋━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━╋" to {_lore::*}
	add "" to {_lore::*}
	add " &a&l🔴&7ヒール" to {_lore::*}
	add "" to {_lore::*}
	add "&e&m╋━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━╋" to {_lore::*}
	add "" to {_lore::*}
	set {_item} to charcoal of sharpness 1 with model data 2 named "&d&l&n不死の肉叢" with lore {_lore::*} with custom nbt from "{actionId:2}"
	registerAction("zombie", 2, hideItemInfo({_item}))

	delete {_lore::*}
	set {_lore::1} to ""
	set {_lore::2} to "&e&m╋━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━╋"
	set {_lore::3} to ""
	set {_lore::4} to " &b&l&n⊱&7死後の世界より5体のゾンビを召喚する。"
	set {_lore::5} to " &b&l&n⊱&7ゾンビは付近のプレイヤーに襲い掛かる。"
	set {_lore::6} to " &b&l&n⊱&7付近にブロックがないと失敗する。"
	set {_lore::7} to ""
	set {_lore::8} to "&e&m╋━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━╋"
	set {_lore::9} to ""
