	add "&e&mв•Ӣв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв•Ӣ" to {_lore::*}
	add "" to {_lore::*}
	set {_item} to nether star of sharpness 1 with model data 1 named "&4&l&nз©әзҲҶ" with lore {_lore::*} with custom nbt from "{actionId:7}"
	registerAction("{@characterId}", 7, hideItemInfo({_item}))

function {@characterId}_action1(player: player):
	cooldown({_player}, {_player}'s tool, 2 second)
	create fake explosion at {_player}
	command "/particle minecraft:explosion %x of {_player}% %y of {_player}% %z of {_player}% 0 0 0 1 3"
	set {_loc} to {_player}'s eye
	loop 10 times:
		command "/particle minecraft:explosion %x of {_loc}% %y of {_loc}% %z of {_loc}% 0 0 0 1 1"
		attenuatedDamage({_player}, {_loc}, 2, 12, 0.3)
		set {_loc} to location forward {_loc}
	distance between {_player} and {_player}'s target player <= 10
	force {_player} to damage {_player}'s target player by 2 heart

function {@characterId}_action2(player: player):
	cooldown({_player}, {_player}'s tool, 2 second)
	create fake explosion at {_player}
	command "/particle minecraft:explosion %x of {_player}% %y of {_player}% %z of {_player}% 0 0 0 1 3"
	set {_loc} to {_player}'s eye
	loop 12 times:
		command "/particle minecraft:explosion %x of {_loc}% %y of {_loc}% %z of {_loc}% 0 0 0 1 1"
		attenuatedDamage({_player}, {_loc}, 2, 12, 0.3)
		set {_loc} to location forward {_loc}
	distance between {_player} and {_player}'s target player <= 12
	force {_player} to damage {_player}'s target player by 3 heart

function {@characterId}_action3(player: player):
	cooldown({_player}, {_player}'s tool, 7 second)
	play sound "custom:yubipattin" to all players where [distance between {_player} and input <= 15]
	command "/particle minecraft:explosion %x-loc of {_loc}% %y-loc of {_loc}% %z-loc of {_loc}% 1.5 1.5 1.5 1 100"
	set {_loc} to {_player}'s eye
	set {_speed} to 0.01
	loop 4*12 times:
		wait 1 tick
		drawSphere({_loc}, 0.05, 50, red)
		add 0.01 to {_speed}
		if loop-number > 35:
			add 0.05 to {_speed}
		set {_loc} to location {_speed} meter forward {_loc}
		loop all players in radius 1.5 around {_loc}:
			isSameTeam({_player}, loop-player) is false
			gamemode of loop-player is adventure
			exit 2 loops
		if block at {_loc} is not air:
			exit loop
	create fake explosion at {_loc}
	attenuatedDamage({_player}, {_loc}, 5, 20, 0.3)
	command "/particle minecraft:explosion %x of {_loc}% %y of {_loc}% %z of {_loc}% 1.5 1.5 1.5 1 100"

function {@characterId}_action4(player: player):
	cooldown({_player}, {_player}'s tool, 4 second)
	create fake explosion at {_player}
	command "/particle minecraft:explosion %x of {_player}% %y of {_player}% %z of {_player}% 0 0 0 1 3"
	push {_player} forward at speed 1.5

function {@characterId}_action5(player: player):
	cooldown({_player}, {_player}'s tool, 8 second)
	set {_loc} to location 5 meter forward {_player}
	drawSphere({_loc}, 3, 300, red)
	create fake explosion at {_loc}
	attenuatedDamage({_player}, {_loc}, 5, 25, 0.5)
	wait 1 second
	set {_loc} to location 5 meter forward {_loc}
	drawSphere({_loc}, 3, 300, blue)
	create fake explosion at {_loc}
	attenuatedDamage({_player}, {_loc}, 5, 25, 0.5)
	wait 1 second
	set {_loc} to location 5 meter forward {_loc}
	drawSphere({_loc}, 3, 300, yellow)
	create fake explosion at {_loc}
	attenuatedDamage({_player}, {_loc}, 5, 25, 0.5)

function {@characterId}_action6(player: player):
	cooldown({_player}, {_player}'s tool, 8 second)
	set {_ray} to raytrace from {_player} with max distance 30 with ray size 0.1
	set {_loc} to hit location of {_ray}
	create fake explosion at {_loc}
	command "/particle minecraft:explosion %x of {_loc}% %y of {_loc}% %z of {_loc}% 1.5 1.5 1.5 1 100"
	command "/particle minecraft:flame %x of {_loc}% %y of {_loc}% %z of {_loc}% 1.5 1.5 1.5 1 30"
	command "/particle dust_pillar{block_state:{Name:lava}} %x of {_loc}% %y of {_loc}% %z of {_loc}% .2 .2 .2 .0001 500 force"
	play sound "custom:bang" to all players where [distance between {_player} and input <= 15]
	attenuatedDamage({_player}, {_loc}, 5, 20, 0.5)

function {@characterId}_action7(player: player):
	cooldown({_player}, {_player}'s tool, 20 second)
	set {_loc} to location 10 meter up {_player}
	set {_loc2} to location 3 meter left {_loc}
	loop 5 times:
		set {_loc2} to location 7 meter horizontally forward {_loc2}
		{@characterId}_airStrike({_player}, {_loc2})
	set {_loc2} to location 3 meter right {_loc}
	loop 5 times:
		set {_loc2} to location 7 meter horizontally forward {_loc2}
		{@characterId}_airStrike({_player}, {_loc2})

function {@characterId}_airStrike(attacker: player, loc: location):
	set {_vector} to vector(0.6, 0, 0)
	loop 30 times:
		draw 1 of dust particle using dustOption(white, 1) at {_loc}~{_vector} with extra 0
		rotate {_vector} around y-axis by 6
	loop 100 times:
		wait 1 tick
		set {_loc} to location 0.2 meter under {_loc}
		draw 1 of dust particle using dustOption(white, 1) at {_loc} with extra 0
		if block at {_loc} is not air:
			exit loop
	drawSphere({_loc}, 3, 500, red)
	create fake explosion at {_loc}
	attenuatedDamage({_attacker}, {_loc}, 5, 30, 0.5)

on death of player:
	getPlayerCharacterId(attacker) is "bomb"
	heal attacker by 7 heart