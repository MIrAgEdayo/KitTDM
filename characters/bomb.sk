options:
	prefix: &7&l[&c&lGame&7&l]
	characterId: bomb

on load:
	set {_value} to ""
	set {_signature} to ""
	registerSkin("{@characterId}", {_value}, {_signature})

	set {character::{@characterId}::head} to head from value {_value}
	registerCharacter("{@characterId}", 13, 25, 1, 1, 1)

	set {_lore::1} to ""
	set {_lore::2} to "&b&l&nвҠұ&7гӮӯгғЈгғ©иӘ¬жҳҺ"
	set {_lore::3} to ""
	add "&fгҖҢд»•ж–№гҒӘгҒ„ зҡҶж®әгҒ—гӮігғјгӮ№гҒӢгҒӘгҖӮгҖҚ" to {_lore::*}
	set {character::{@characterId}::icon} to getHeadFromCharacterId("{@characterId}") named "&7[&6&lгғҒгӮ§гғігӮҪгғјгғһгғі&7] &4&lгғңгғ " with lore {_lore::*} with custom nbt from "{pickable:false}"

	delete {_lore::*}
	add "" to {_lore::*}
	add "&e&mв•Ӣв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв•Ӣ" to {_lore::*}
	add "" to {_lore::*}
	add " &b&l&nвҠұ&7зҲҶзҷәгҒ§еЁҒеҠӣгҒҢеў—еӨ§гҒ—гҒҹгғ‘гғігғҒ" to {_lore::*}
	add "" to {_lore::*}
	add "&e&mв•Ӣв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв•Ӣ" to {_lore::*}
	add "" to {_lore::*}
	set {_item} to raw iron of sharpness 1 with model data 1 named "&c&l&nж®ҙгӮӢ" with lore {_lore::*} with custom nbt from "{actionId:1}"
	registerAction("{@characterId}", 1, hideItemInfo({_item}))

	delete {_lore::*}
	add "" to {_lore::*}
	add "&e&mв•Ӣв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв•Ӣ" to {_lore::*}
	add "" to {_lore::*}
