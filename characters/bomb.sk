	add "&e&mв•Ӣв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв•Ӣ" to {_lore::*}
	add "" to {_lore::*}
	set {_item} to feather of sharpness 1 with model data 1 named "&c&l&nжҢҮгғ‘гғғгғҒгғі" with lore {_lore::*} with custom nbt from "{actionId:3}"
	registerAction("{@characterId}", 3, hideItemInfo({_item}))

	delete {_lore::*}
	add "" to {_lore::*}
	add "&e&mв•Ӣв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв•Ӣ" to {_lore::*}
	add "" to {_lore::*}
	add " &b&l&nвҠұ&7и¶іе…ғгҒ§зҲҶзҷәгӮ’иө·гҒ“гҒ—еүҚж–№гҒ«еҠ йҖҹ" to {_lore::*}
	add "" to {_lore::*}
	add "&e&mв•Ӣв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв•Ӣ" to {_lore::*}
	add "" to {_lore::*}
	set {_item} to blaze powder of sharpness 1 with model data 1 named "&6&l&nгӮўгӮҜгӮ»гғ«" with lore {_lore::*} with custom nbt from "{actionId:4}"
	registerAction("{@characterId}", 4, hideItemInfo({_item}))

	delete {_lore::*}
	add "" to {_lore::*}
	add "&e&mв•Ӣв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв•Ӣ" to {_lore::*}
	add "" to {_lore::*}
	add " &b&l&nвҠұ&7еүҚж–№гҒ«3ж®өгҒ®зү№еӨ§зҲҶзҷә" to {_lore::*}
	add "" to {_lore::*}
	add "&e&mв•Ӣв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв•Ӣ" to {_lore::*}
	add "" to {_lore::*}
	set {_item} to clock of sharpness 1 with model data 1 named "&d&l&nгӮ«гғ©гғ•гғ«гғңгғ " with lore {_lore::*} with custom nbt from "{actionId:5}"
	registerAction("{@characterId}", 5, hideItemInfo({_item}))

	delete {_lore::*}
	add "" to {_lore::*}
	add "&e&mв•Ӣв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв•Ӣ" to {_lore::*}
	add "" to {_lore::*}
	add " &b&l&nвҠұ&7иҰ–з·ҡгҒ®е…ҲгӮ’зҲҶз ҙ" to {_lore::*}
	add "" to {_lore::*}
	add "&e&mв•Ӣв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв•Ӣ" to {_lore::*}
	add "" to {_lore::*}
	set {_item} to tnt of sharpness 1 with model data 1 named "&d&l&nгғҗгғігғғ" with lore {_lore::*} with custom nbt from "{actionId:6}"
	registerAction("{@characterId}", 6, hideItemInfo({_item}))

	delete {_lore::*}
	add "" to {_lore::*}
	add "&e&mв•Ӣв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв•Ӣ" to {_lore::*}
	add "" to {_lore::*}
	add " &b&l&nвҠұ&7еүҚж–№гҒ«з©әзҲҶгӮ’иЎҢгҒҶ" to {_lore::*}
